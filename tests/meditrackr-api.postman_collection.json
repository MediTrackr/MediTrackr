{
  "info": {
    "name": "MediTrackr API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "authToken", "value": "" }
  ],
  "item": [
    {
      "name": "OCR",
      "item": [
        {
          "name": "Health Card — 401 without auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 401 when unauthenticated', () => {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"image\": \"data:image/jpeg;base64,/9j/4AAQ\"}"
            },
            "url": "{{baseUrl}}/api/ocr/health-card"
          }
        },
        {
          "name": "Health Card — rejects empty body (no auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns non-2xx for missing image (auth enforced first)', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 401]);",
                  "});",
                  "pm.test('error message present', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('error');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/api/ocr/health-card"
          }
        },
        {
          "name": "Smart Scan — 401 without auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 401 when unauthenticated', () => {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"image\": \"data:image/jpeg;base64,/9j/4AAQ\"}"
            },
            "url": "{{baseUrl}}/api/ocr/smart-scan"
          }
        },
        {
          "name": "Smart Scan — rejects empty body (no auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns non-2xx for missing image (auth enforced first)', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 401]);",
                  "});",
                  "pm.test('error message present', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('error');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/api/ocr/smart-scan"
          }
        },
        {
          "name": "Expense Receipt — 401 without auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 401 when unauthenticated', () => {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"image\": \"data:image/jpeg;base64,/9j/4AAQ\"}"
            },
            "url": "{{baseUrl}}/api/ocr/expense-receipt"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Link — 401 without auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 401 when unauthenticated', () => {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"invoiceId\": \"test-123\", \"amount\": 100, \"patientName\": \"Test Patient\", \"patientEmail\": \"test@example.com\"}"
            },
            "url": "{{baseUrl}}/api/create-payment-link"
          }
        },
        {
          "name": "Stripe Webhook — 400 bad signature",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 400 for invalid signature', () => {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "t=invalid,v1=badsig" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"type\": \"checkout.session.completed\"}"
            },
            "url": "{{baseUrl}}/api/stripe-webhook"
          }
        }
      ]
    },
    {
      "name": "Swagger",
      "item": [
        {
          "name": "GET /api/api-docs — spec loads",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('is valid OpenAPI spec', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('openapi');",
                  "  pm.expect(body).to.have.property('paths');",
                  "  pm.expect(body.info.title).to.eql('MediTrackr API');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/api-docs"
          }
        }
      ]
    }
  ]
}
